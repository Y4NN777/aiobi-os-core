#!/usr/bin/env python3
# aiobi-term — terminal AI assistant for Aïobi OS
#
# Talks to a locally-bound Ollama daemon on http://127.0.0.1:11434.
#
# Modes
#   aiobi-term "<question>"          conversational   (chat system prompt)
#   aiobi-term --cmd "<request>"     shell command    (cmd system prompt +
#                                                     deterministic decoding)
#   aiobi-term --chat                interactive REPL
#
# Model
#   A single small language model (qwen2.5:1.5b) serves both modes. The
#   two modes differ by system prompt and sampling — chat runs with the
#   model's default sampling, cmd runs deterministic (temperature 0) with
#   few-shot examples for tight shell-command extraction. Consolidating on
#   one model saves ~400 MB of RAM footprint versus a separate coder
#   variant, at the cost of some flexibility in output shape for cmd mode
#   (which is compensated by prompt engineering + post-processing below).
#
# Contract
#   * stdlib only — no pip install required.
#   * loopback only — every request goes to 127.0.0.1:11434, no other host
#     is ever contacted. If the daemon is unreachable the tool prints an
#     actionable hint and exits non-zero.
#   * user confirmation is required for every shell command: the model
#     returns a suggestion, aiobi-term prints it, and the user decides
#     whether to run it. aiobi-term itself does NOT execute the suggestion.
#   * destructive-pattern guardrail: the CODE_SYSTEM prompt asks the
#     model to emit destructive suggestions as two lines — a '# ' warning
#     followed by the actual command — so the user sees both the risk
#     and the command. When the model omits the warning and the output
#     matches a known dangerous pattern (rm -rf, dd of=/dev/, mkfs,
#     chmod 777 /, fork bomb, curl | sh, etc.), do_command PREPENDS a
#     '# WARNING' line so the risk is always visible above the command.

import argparse
import json
import re
import sys
import urllib.request
import urllib.error


OLLAMA_ENDPOINT = "http://127.0.0.1:11434/api/generate"

MODEL = "qwen2.5:1.5b"

CHAT_SYSTEM = (
    "You are the Aïobi terminal assistant, the built-in AI of Aïobi OS. "
    "Answer the user's question concisely and in the language they used. "
    "If they ask about system administration, prefer Ubuntu 24.04 conventions."
)

CODE_SYSTEM = (
    "You translate the user's natural-language request into a single "
    "safe shell command for Ubuntu 24.04. Output ONLY the command, on "
    "one line, with no explanation, no markdown, no code fence, no "
    "leading '$', no trailing comment, no trailing punctuation. "
    "Prefer modern Ubuntu 24.04 tools over deprecated ones: use ss "
    "instead of netstat, ip instead of ifconfig, dig instead of "
    "nslookup, journalctl instead of tailing /var/log directly. "
    "If the request is destructive or ambiguous, output TWO lines: "
    "first a warning line starting with '# ' and a one-sentence "
    "justification, then the actual shell command on the second line. "
    "The user sees the warning AND has the command ready to review.\n"
    "\n"
    "Examples:\n"
    "Request: list every running service\n"
    "Command: systemctl list-units --type=service --state=running\n"
    "\n"
    "Request: show free disk on the root filesystem\n"
    "Command: df -h /\n"
    "\n"
    "Request: top 10 processes by memory usage\n"
    "Command: ps aux --sort=-%mem | head -n 11\n"
    "\n"
    "Request: list all listening TCP ports\n"
    "Command: ss -tln\n"
    "\n"
    "Request: delete every log file in /var/log\n"
    "Command: # destructive; wholesale removal of /var/log breaks audit trails, name the specific file first\n"
    "rm -rf /var/log/*.log\n"
    "\n"
    "Request: format /dev/sda\n"
    "Command: # destructive; run lsblk first, confirm the target device, then use mkfs with the intended filesystem\n"
    "mkfs.ext4 /dev/sda\n"
    "\n"
    "Request: wipe the second disk with zeros\n"
    "Command: # destructive; dd of=/dev/<device> is unrecoverable, verify with lsblk that no partitions are mounted\n"
    "dd if=/dev/zero of=/dev/sdb bs=1M status=progress"
)

CMD_DECODING_OPTIONS = {
    "temperature": 0,
    "top_k": 1,
    "top_p": 0.1,
    "num_predict": 128,
}

# Safety net for --cmd mode. The CODE_SYSTEM prompt already asks the
# model to prefix destructive suggestions with '# ', but a 1.5B model
# does not reliably generalise the pattern to every destructive shape.
# When the stripped model output matches one of these patterns and is
# not already commented, do_command() replaces the raw command with a
# warning line — the user must then rephrase or type the command
# manually. Zero accidental execution of a paste from aiobi-term.
DESTRUCTIVE_PATTERNS = (
    (re.compile(r"\brm\s+(-[a-zA-Z]*[rRfF]|--recursive|--force)\b"),
     "recursive or forced rm"),
    (re.compile(r"\bdd\s+.*\bof=/dev/"),
     "dd writing to a raw device"),
    (re.compile(r"\bmkfs\.[a-z0-9]+\b"),
     "filesystem format (mkfs)"),
    (re.compile(r"\bfdisk\s+/dev/"),
     "fdisk on a raw device"),
    (re.compile(r"\bchmod\s+(-R\s+)?[0-7]?[67][0-7]{2}\s+/"),
     "chmod with world-write on a system path"),
    (re.compile(r"\bchown\s+-R\s+\S+\s+/(?!home)"),
     "recursive chown on a system path"),
    (re.compile(r"^\s*>\s*/etc/"),
     "redirect that would truncate an /etc/ file"),
    (re.compile(r"\b(shutdown|reboot|poweroff|halt)\b"),
     "system power state change"),
    (re.compile(r":\(\)\s*\{[^}]*\|:[^}]*\}"),
     "fork bomb"),
    (re.compile(r"(wget|curl)\s[^|]*\|\s*(sh|bash)"),
     "piping remote content directly to a shell"),
)


def is_destructive(command: str):
    """Return the destructive reason string if the command matches a
    known dangerous pattern, else None. A command already commented
    out (leading '#') is treated as pre-warned and returned as safe."""
    if not command or command.lstrip().startswith("#"):
        return None
    for pattern, reason in DESTRUCTIVE_PATTERNS:
        if pattern.search(command):
            return reason
    return None


def call_ollama(system: str, prompt: str, options: dict | None = None,
                timeout: float = 60.0) -> str:
    payload = {
        "model": MODEL,
        "system": system,
        "prompt": prompt,
        "stream": False,
    }
    if options:
        payload["options"] = options
    body = json.dumps(payload).encode("utf-8")

    req = urllib.request.Request(
        OLLAMA_ENDPOINT,
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            data = json.load(resp)
            return (data.get("response") or "").strip()
    except urllib.error.URLError as exc:
        sys.stderr.write(
            "aiobi-term: cannot reach the local Ollama daemon on 127.0.0.1:11434\n"
            f"           reason: {exc.reason}\n"
            "           hint  : run `systemctl start ollama` and retry\n"
        )
        sys.exit(2)
    except Exception as exc:
        sys.stderr.write(f"aiobi-term: unexpected error: {exc}\n")
        sys.exit(3)


def strip_fences(text: str) -> str:
    """Strip markdown code fences, wrapping backticks, and leading '$ '
    from a model response, then collapse to the first non-empty line,
    so the user can pipe or paste the result as-is."""
    text = text.strip()
    # Triple-backtick block: ```bash\n...\n```
    text = re.sub(r"^```[a-zA-Z0-9]*\n", "", text)
    text = re.sub(r"\n```\s*$", "", text)
    text = text.strip()
    # Single wrapping backticks: `command`
    if len(text) >= 2 and text.startswith("`") and text.endswith("`"):
        text = text[1:-1].strip()
    # Leading '$ ' or '$' prompt char that some models add
    if text.startswith("$ "):
        text = text[2:]
    elif text.startswith("$"):
        text = text[1:].lstrip()
    # The CODE_SYSTEM contract allows two shapes:
    #   1. a single command line (most requests)
    #   2. a warning line starting with '#' followed by the actual
    #      command line (destructive / ambiguous requests)
    # In shape 1, take the first non-empty line and drop any trailing
    # prose. In shape 2, preserve both lines — the user sees the
    # warning AND has the command to review.
    lines = [ln.strip() for ln in text.split("\n") if ln.strip()]
    if not lines:
        return text
    if lines[0].startswith("#") and len(lines) >= 2:
        return f"{lines[0]}\n{lines[1]}"
    return lines[0]


def do_command(request: str) -> None:
    response = call_ollama(CODE_SYSTEM, request, options=CMD_DECODING_OPTIONS)
    cmd = strip_fences(response)
    # Safety net: if the model returned a raw destructive command with
    # no leading '# ' warning, prepend one so the user always sees the
    # risk before the command line — the command is still printed and
    # copy-runnable, but the '#' line above it is a shell comment that
    # makes the intent visible.
    lines = cmd.split("\n")
    first_line = lines[0].lstrip()
    if not first_line.startswith("#"):
        reason = is_destructive(cmd)
        if reason:
            print(
                f"# WARNING: destructive pattern detected ({reason}). "
                f"Review the target and consequences before running."
            )
    print(cmd)


def do_chat(question: str) -> None:
    response = call_ollama(CHAT_SYSTEM, question)
    print(response)


def do_repl() -> None:
    print("aiobi-term — interactive chat. Type 'exit' to quit.")
    print(f"             (uses {MODEL} on 127.0.0.1:11434)")
    while True:
        try:
            line = input("you> ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return
        if not line:
            continue
        if line.lower() in {"exit", "quit", "bye"}:
            return
        print("ai>  " + call_ollama(CHAT_SYSTEM, line))


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="aiobi-term",
        description=(
            "Aïobi OS terminal AI assistant — talks to the local Ollama "
            "daemon bound on 127.0.0.1:11434."
        ),
    )
    parser.add_argument("--cmd", action="store_true",
                        help="Return a shell command suggestion instead of a chat answer.")
    parser.add_argument("--chat", action="store_true",
                        help="Start an interactive chat REPL.")
    parser.add_argument("prompt", nargs="*",
                        help="The question or request. Read from stdin if empty.")
    args = parser.parse_args()

    if args.chat:
        do_repl()
        return 0

    if args.prompt:
        request = " ".join(args.prompt)
    elif not sys.stdin.isatty():
        request = sys.stdin.read().strip()
    else:
        parser.print_help(sys.stderr)
        return 1

    if args.cmd:
        do_command(request)
    else:
        do_chat(request)
    return 0


if __name__ == "__main__":
    sys.exit(main())
