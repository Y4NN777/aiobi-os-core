# Aïobi OS — system-wide branding defaults (NOT locked except theme keys)
# Installed at /etc/dconf/db/local.d/00-aiobi-branding
#
# CRITICAL: color-scheme is NOT set here and NOT locked anywhere — the user
# must remain free to toggle light/dark via Settings → Appearance. Locking
# color-scheme would break the OS for any user who prefers light mode.
#
# Source: https://help.gnome.org/admin/system-admin-guide/stable/dconf-keyfiles.html
#
# Additional keys installed alongside the initial branding:
#   - Fonts changed Satoshi → Inter (Satoshi is app-level design system,
#     not OS-level; Inter is neutral system font, ships in Ubuntu universe
#     via `fonts-inter` package — installed by 06-apply-persistence.sh).
#   - user-theme.name changed '' → 'Aiobi' (activates the shipped shell theme
#     Aïobi installed by 08-inject-shell-theme.sh).

[org/gnome/desktop/interface]
gtk-theme='Aiobi'
icon-theme='Aiobi'
cursor-theme='Yaru'
font-name='Inter 11'
document-font-name='Inter 11'
monospace-font-name='JetBrains Mono 11'

[org/gnome/shell/extensions/user-theme]
# Aïobi shell theme activation. Requires gnome-shell-extensions package
# (provides user-theme extension) — installed by 06-apply-persistence.sh.
# The Aïobi shell theme itself is installed by 08-inject-shell-theme.sh.
name='Aiobi'
